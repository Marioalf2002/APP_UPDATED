            "pm.test('Productos de niños tienen precioFinal con descuento', () => {",
            "  const ninos = pm.response.json().productos.filter(p => p.audiencia === 'ninos');",
            "  ninos.forEach(p => pm.expect(p.precioFinal).to.be.lessThan(p.precio));",
            "});"
